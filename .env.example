# ----------------------------------------------------------------------------
# Cross-service defaults for the laravel-fastapi-demo stack.
# Copy to .env (never commit) and adjust for your environment.
# All services in docker-compose.yml use `env_file: .env`.
# ----------------------------------------------------------------------------

# --- Postgres ---------------------------------------------------------------
POSTGRES_DB=enterprise_core
POSTGRES_USER=db_user
POSTGRES_PASSWORD=db_password

# --- Laravel app ------------------------------------------------------------
# Override per environment. The default `local` keeps config/route caching
# disabled in entrypoint.sh; set to `production` to enable caches on boot.
APP_ENV=local

# --- Redis ------------------------------------------------------------------
REDIS_HOST=ai_redis
REDIS_PORT=6379

# --- Inter-service URLs (internal Docker network) ---------------------------
# Used by Laravel to call the FastAPI engine.
FASTAPI_INTERNAL_URL=http://ai_fastapi_engine:8000
# Used by the FastAPI engine to POST callbacks back to Laravel.
LARAVEL_BASE_URL=http://ai_laravel_app

# --- Reverb (Laravel WebSockets) -------------------------------------------
REVERB_APP_ID=enterprise-app
REVERB_APP_KEY=reverb-local-key
REVERB_APP_SECRET=reverb-local-secret
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=http

# --- HMAC shared secret -----------------------------------------------------
# Used to authenticate FastAPI -> Laravel callbacks on /api/ai-callback/{uuid}.
# Both services must agree on the same value. Rotate together in production.
CALLBACK_HMAC_SECRET=dev-only-change-me

# --- Observability ----------------------------------------------------------
# OpenTelemetry: set to enable distributed tracing (gRPC endpoint).
# Leave empty to disable.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=ai-fastapi-engine

# --- LLM (DeepSeek / OpenAI-compatible) -------------------------------------
# Used by the FastAPI engine for real chat completions. Keep secret.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# --- HuggingFace Hub --------------------------------------------------------
# Token for faster embedding model downloads (BAAI/bge-small-en-v1.5).
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=
