APP_NAME=EnterpriseOrchestrator
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
ASSET_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=ai_postgres
DB_PORT=5432
DB_DATABASE=enterprise_core
DB_USERNAME=db_user
DB_PASSWORD=db_password

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_CLIENT=phpredis
REDIS_HOST=ai_redis
REDIS_PORT=6379
REDIS_PASSWORD=null

REVERB_APP_ID=enterprise-app
REVERB_APP_KEY=reverb-local-key
REVERB_APP_SECRET=reverb-local-secret
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=http

FASTAPI_INTERNAL_URL=http://ai_fastapi_engine:8000
CALLBACK_HMAC_SECRET=dev-only-change-me

# Used by the FastAPI engine (not Laravel directly).
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
