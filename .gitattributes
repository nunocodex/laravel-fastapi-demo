# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts must always use LF (even when contributors edit on Windows)
*.sh        text eol=lf
*.bash      text eol=lf
Dockerfile  text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.md        text eol=lf

# Binary
*.png  binary
*.jpg  binary
*.ico  binary
